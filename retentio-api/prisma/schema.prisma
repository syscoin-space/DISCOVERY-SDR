generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String                 @id @default(uuid())
  name              String
  slug              String                 @unique
  discovery_enabled Boolean                @default(false)
  active            Boolean                @default(true)
  settings          Json?
  branding          Json?
  created_at        DateTime               @default(now())
  updated_at        DateTime               @updatedAt
  onboarding_status OnboardingStatus       @default(PENDING)
  onboarding_step   Int                    @default(0)
  plan_id           String?
  audit_logs        AuditLog[]
  cadences          Cadence[]
  call_scripts      CallScript[]
  goals             Goal[]
  leads             Lead[]
  memberships       Membership[]
  notifications     Notification[]
  onboarding        OnboardingState?
  subscription      Subscription?
  teams             Team[]
  templates         Template[]
  ai_providers      TenantAIProvider[]
  ai_settings       TenantAISettings?
  email_providers   TenantEmailProvider[]
  invitations       MembershipInvitation[]
  interactions      Interaction[]
  email_events      EmailEvent[]
  plan              Plan?                  @relation(fields: [plan_id], references: [id])

  @@map("tenants")
}

model SystemConfig {
  id         String   @id @default("GLOBAL")
  branding   Json?
  settings   Json?
  updated_at DateTime @updatedAt

  @@map("system_configs")
}

model TenantAIProvider {
  id                String         @id @default(uuid())
  tenant_id         String
  provider          AIProviderType
  is_enabled        Boolean        @default(false)
  api_key_encrypted String?
  default_model     String?
  base_url          String?
  is_default        Boolean        @default(false)
  priority_order    Int            @default(0)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, provider])
  @@map("tenant_ai_providers")
}

model TenantAISettings {
  tenant_id                      String          @id
  ai_enabled                     Boolean         @default(false)
  default_provider               AIProviderType?
  classification_provider        AIProviderType?
  summary_provider               AIProviderType?
  guidance_provider              AIProviderType?
  allow_fallback                 Boolean         @default(true)
  fallback_provider              AIProviderType?
  human_review_required          Boolean         @default(true)
  persist_ai_metadata_by_default Boolean         @default(true)
  updated_at                     DateTime        @updatedAt
  tenant                         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_ai_settings")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password_hash String
  name          String
  avatar_url    String?
  active        Boolean      @default(true)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  memberships   Membership[]

  @@index([email])
  @@map("users")
}

model Membership {
  id                 String             @id @default(uuid())
  user_id            String
  tenant_id          String
  role               Role
  capacity           Int?
  team_id            String?
  active             Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  google_integration GoogleIntegration?
  handoffs_received  HandoffBriefing[]  @relation("HandoffCloser")
  handoffs_sent      HandoffBriefing[]  @relation("HandoffSdr")
  distributed_leads  Lead[]             @relation("DistributedBy")
  assigned_leads     Lead[]             @relation("AssignedSDR")
  team               Team?              @relation(fields: [team_id], references: [id])
  tenant             Tenant             @relation(fields: [tenant_id], references: [id])
  user               User               @relation(fields: [user_id], references: [id])
  push_subscriptions PushSubscription[]
  tasks              Task[]
  touchpoints        Touchpoint[]
  interactions       Interaction[]

  @@unique([user_id, tenant_id])
  @@index([tenant_id, role])
  @@index([tenant_id, team_id])
  @@map("memberships")
}

model Team {
  id         String       @id @default(uuid())
  tenant_id  String
  name       String
  manager_id String?
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  members    Membership[]
  tenant     Tenant       @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("teams")
}

model Lead {
  id                  String              @id @default(uuid())
  tenant_id           String
  sdr_id              String?
  distributed_by      String?
  status              LeadStatus          @default(BANCO)
  company_name        String
  domain              String?
  cnpj                String?
  segment             String?
  company_size        String?
  contact_name        String?
  contact_role        String?
  email               String?
  phone               String?
  whatsapp            String?
  instagram           String?
  linkedin            String?
  city                String?
  state               String?
  source              String?
  notes               String?
  icp_score           Int?
  best_channel        String?
  distributed_at      DateTime?
  imported_at         DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  direct_email        String?
  direct_phone        String?
  discovery_notes     String?
  discovery_status    DiscoveryStatus     @default(SEARCHING_DM)
  dm_name             String?
  dm_role             String?
  last_touchpoint_id  String?
  operational_score   Float               @default(0.0)
  preferred_channel   String?
  ai_metadata         Json?
  audit_logs          AuditLog[]
  cadence_enrollments CadenceEnrollment[]
  calendar_events     CalendarEvent[]
  handoffs            HandoffBriefing[]
  interactions        Interaction[]
  discovered_stack    DiscoveredStack[]
  distributor         Membership?         @relation("DistributedBy", fields: [distributed_by], references: [id])
  sdr                 Membership?         @relation("AssignedSDR", fields: [sdr_id], references: [id])
  tenant              Tenant              @relation(fields: [tenant_id], references: [id])
  tasks               Task[]
  touchpoints         Touchpoint[]

  @@unique([domain, tenant_id])
  @@unique([email, tenant_id])
  @@index([tenant_id, status])
  @@index([tenant_id, sdr_id])
  @@index([tenant_id, sdr_id, status])
  @@index([company_name])
  @@map("leads")
}

model DiscoveredStack {
  id         String   @id @default(uuid())
  lead_id    String
  tenant_id  String
  category   String
  tool_name  String
  created_at DateTime @default(now())
  lead       Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@index([tenant_id, lead_id])
  @@map("discovered_stacks")
}

model Task {
  id                    String             @id @default(uuid())
  tenant_id             String
  lead_id               String?
  membership_id         String
  type                  TaskType
  status                TaskStatus         @default(PENDENTE)
  title                 String
  description           String?
  channel               String?
  outcome               String?
  scheduled_at          DateTime?
  completed_at          DateTime?
  due_at                DateTime?
  cadence_enrollment_id String?
  cadence_step_id       String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  cadence_enrollment    CadenceEnrollment? @relation(fields: [cadence_enrollment_id], references: [id])
  cadence_step          CadenceStep?       @relation(fields: [cadence_step_id], references: [id])
  lead                  Lead?              @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  membership            Membership         @relation(fields: [membership_id], references: [id])

  @@index([membership_id, status, scheduled_at])
  @@index([tenant_id, type, status])
  @@index([lead_id])
  @@index([cadence_enrollment_id])
  @@map("tasks")
}

model Cadence {
  id          String              @id @default(uuid())
  tenant_id   String
  name        String
  purpose     CadencePurpose
  description String?
  active      Boolean             @default(true)
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  enrollments CadenceEnrollment[]
  steps       CadenceStep[]
  tenant      Tenant              @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, purpose, active])
  @@map("cadences")
}

model CadenceStep {
  id           String        @id @default(uuid())
  cadence_id   String
  step_order   Int
  day_offset   Int
  channel      String
  template_id  String?
  instructions String?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  cadence      Cadence       @relation(fields: [cadence_id], references: [id], onDelete: Cascade)
  template     Template?     @relation(fields: [template_id], references: [id])
  tasks        Task[]
  interactions Interaction[]

  @@unique([cadence_id, step_order])
  @@map("cadence_steps")
}

model CadenceEnrollment {
  id           String           @id @default(uuid())
  lead_id      String
  cadence_id   String
  current_step Int              @default(1)
  status       EnrollmentStatus @default(ACTIVE)
  started_at   DateTime         @default(now())
  completed_at DateTime?
  cadence      Cadence          @relation(fields: [cadence_id], references: [id])
  lead         Lead             @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@unique([lead_id, cadence_id])
  @@index([status])
  @@map("cadence_enrollments")
}

model Template {
  id            String          @id @default(uuid())
  tenant_id     String
  name          String
  channel       String
  purpose       TemplatePurpose
  subject       String?
  body          String
  variables     Json?
  version       Int             @default(1)
  active        Boolean         @default(true)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  cadence_steps CadenceStep[]
  tenant        Tenant          @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, channel, purpose])
  @@map("templates")
}

model Touchpoint {
  id               String            @id @default(uuid())
  lead_id          String
  membership_id    String
  sequence_number  Int
  channel          String
  touchpoint_type  String
  outcome          TouchpointOutcome
  answered         Boolean?
  booked           Boolean?
  lost             Boolean?
  duration_seconds Int?
  notes            String?
  created_at       DateTime          @default(now())
  lead             Lead              @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  membership       Membership        @relation(fields: [membership_id], references: [id])

  @@index([lead_id, created_at(sort: Desc)])
  @@map("touchpoints")
}

model Interaction {
  id              String            @id @default(uuid())
  tenant_id       String
  lead_id         String
  membership_id   String?
  cadence_step_id String?
  type            InteractionType
  source          InteractionSource @default(MANUAL)
  channel         String?
  external_id     String?
  subject         String?
  body            String?
  status          String?
  error           String?
  metadata        Json?
  created_at      DateTime          @default(now())
  email_events    EmailEvent[]
  lead            Lead              @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant          Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cadence_step    CadenceStep?      @relation(fields: [cadence_step_id], references: [id])
  membership      Membership?       @relation(fields: [membership_id], references: [id])

  @@index([lead_id, created_at(sort: Desc)])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([external_id])
  @@map("interactions")
}

model EmailEvent {
  id                  String       @id @default(uuid())
  tenant_id           String
  interaction_id      String?
  lead_id             String?
  cadence_step_id     String?
  provider            EmailProviderType @default(RESEND)
  external_message_id String
  provider_event_id   String?
  type                String
  email               String?
  payload             Json?
  timestamp           DateTime?
  created_at          DateTime     @default(now())
  
  interaction         Interaction? @relation(fields: [interaction_id], references: [id])
  tenant              Tenant       @relation(fields: [tenant_id], references: [id])

  @@unique([provider, provider_event_id])
  @@index([external_message_id])
  @@index([interaction_id])
  @@index([tenant_id])
  @@map("email_events")
}

model HandoffBriefing {
  id                    String        @id @default(uuid())
  lead_id               String
  sdr_id                String
  closer_id             String?
  status                HandoffStatus @default(PENDENTE)
  briefing_data         Json
  accepted_at           DateTime?
  returned_at           DateTime?
  return_reason         String?
  return_reentry_status LeadStatus?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt
  closer                Membership?   @relation("HandoffCloser", fields: [closer_id], references: [id])
  lead                  Lead          @relation(fields: [lead_id], references: [id])
  sdr                   Membership    @relation("HandoffSdr", fields: [sdr_id], references: [id])

  @@index([sdr_id])
  @@index([closer_id])
  @@index([status])
  @@map("handoff_briefings")
}

model CalendarEvent {
  id              String   @id @default(uuid())
  google_event_id String?  @unique
  lead_id         String
  closer_id       String
  sdr_id          String
  titulo          String
  descricao       String?
  inicio          DateTime
  fim             DateTime
  meet_link       String?
  status          String   @default("confirmed")
  convidados      String[]
  sincronizado_at DateTime @default(now())
  created_at      DateTime @default(now())
  lead            Lead     @relation(fields: [lead_id], references: [id])

  @@index([lead_id])
  @@index([closer_id])
  @@index([sdr_id])
  @@index([inicio])
  @@map("calendar_events")
}

model GoogleIntegration {
  id            String     @id @default(uuid())
  membership_id String     @unique
  google_email  String
  access_token  String
  refresh_token String
  token_expiry  DateTime
  calendar_id   String     @default("primary")
  scopes        String[]
  active        Boolean    @default(true)
  connected_at  DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  membership    Membership @relation(fields: [membership_id], references: [id], onDelete: Cascade)

  @@map("google_integrations")
}

model Notification {
  id        String   @id @default(uuid())
  tenant_id String
  user_id   String
  category  String
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  sent_at   DateTime @default(now())
  lead_id   String?
  tenant    Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([user_id, read])
  @@index([tenant_id, category])
  @@index([user_id, sent_at(sort: Desc)])
  @@map("notifications")
}

model PushSubscription {
  id            String     @id @default(uuid())
  membership_id String
  endpoint      String     @unique
  p256dh        String
  auth          String
  user_agent    String?
  created_at    DateTime   @default(now())
  membership    Membership @relation(fields: [membership_id], references: [id], onDelete: Cascade)

  @@index([membership_id])
  @@map("push_subscriptions")
}

model Goal {
  id            String   @id @default(uuid())
  tenant_id     String
  membership_id String?
  type          String
  target        Int
  period        String
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, membership_id])
  @@map("goals")
}

model CallScript {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  block_type String
  content    String
  order      Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, block_type])
  @@map("call_scripts")
}

model TenantEmailProvider {
  id                String            @id @default(uuid())
  tenant_id         String
  provider          EmailProviderType @default(RESEND)
  is_enabled        Boolean           @default(false)
  api_key_encrypted String?
  sender_name       String?
  sender_email      String?
  reply_to          String?
  webhook_secret    String?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, provider])
  @@map("tenant_email_providers")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenant_id   String
  user_id     String?
  lead_id     String?
  action      String
  entity_type String
  entity_id   String
  old_value   Json?
  new_value   Json?
  ip_address  String?
  created_at  DateTime @default(now())
  lead        Lead?    @relation(fields: [lead_id], references: [id])
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, entity_type, entity_id])
  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@map("audit_logs")
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique
  key           String         @unique
  description   String?
  price_monthly Float?
  currency      String         @default("BRL")
  trial_days    Int            @default(7)
  limits        Json
  features      Json
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  subscriptions Subscription[]
  tenants       Tenant[]

  @@map("plans")
}

model Subscription {
  id                      String             @id @default(uuid())
  tenant_id               String             @unique
  plan_id                 String
  status                  SubscriptionStatus @default(TRIAL)
  current_period_start    DateTime           @default(now())
  current_period_end      DateTime?
  cancel_at_period_end    Boolean            @default(false)
  canceled_at             DateTime?
  price                   Float?
  currency                String             @default("BRL")
  last_webhook_at         DateTime?
  metadata                Json?
  gateway_customer_id     String?
  gateway_subscription_id String?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt
  plan                    Plan               @relation(fields: [plan_id], references: [id])
  tenant                  Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model OnboardingState {
  tenant_id       String    @id
  tasks_completed Json
  completed_at    DateTime?
  updated_at      DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("onboarding_states")
}

model MembershipInvitation {
  id         String           @id @default(uuid())
  tenant_id  String
  email      String
  role       Role
  team_id    String?
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  expires_at DateTime
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  tenant     Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, email])
  @@map("membership_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum Role {
  ADMIN
  OWNER
  MANAGER
  SDR
  CLOSER
}

enum LeadStatus {
  BANCO
  CONTA_FRIA
  DISCOVERY
  EM_PROSPECCAO
  FOLLOW_UP
  NUTRICAO
  REUNIAO_MARCADA
  PERDIDO
  QUALIFICADO
  PROSPECCAO
}

enum TaskType {
  CADENCE_STEP
  DISCOVERY_STEP
  MANUAL
  AUTO
  MEETING
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
  ATRASADA
}

enum CadencePurpose {
  DISCOVERY
  PROSPECCAO
  NUTRICAO
  CONFIRMACAO
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED_SUCCESS
  COMPLETED_FAIL
  CANCELLED
}

enum TemplatePurpose {
  PRIMEIRO_CONTATO
  FOLLOW_UP
  NUTRICAO
  CONFIRMACAO_REUNIAO
  REATIVACAO
}

enum EmailProviderType {
  RESEND
  SMTP
}

enum InteractionType {
  EMAIL
  WHATSAPP
  LIGACAO
  LINKEDIN
  REUNIAO
  NOTA
}

enum InteractionSource {
  CADENCIA
  MANUAL
  WEBHOOK
  AUTOMACAO
}

enum TouchpointOutcome {
  NO_ANSWER
  VOICEMAIL
  INVALID_NUMBER
  SEEN_NO_REPLY
  RESPONDED
  SPOKE_GATEKEEPER
  SPOKE_DECISION_MAKER
  ASKED_FOLLOW_UP
  NOT_INTERESTED
  BOOKED
  LOST
  GATEKEEPER_CONTACTED
  DECISION_MAKER_IDENTIFIED
  TRANSFERRED_TO_DM
  DIRECT_CONTACT_FOUND
  COMPANY_UNREACHABLE
  WRONG_CONTACT
  DISCOVERY_COMPLETED
}

enum DiscoveryStatus {
  SEARCHING_DM
  DM_IDENTIFIED
  DM_REACHED
  GATEKEEPER_BLOCKED
  READY_FOR_PROSPECTING
  INSUFFICIENT_DATA
}

enum HandoffStatus {
  PENDENTE
  ACEITO
  DEVOLVIDO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AIProviderType {
  OPENROUTER
  OPENAI
  CLAUDE
  GEMINI
}

enum BillingProvider {
  ASAAS
  STRIPE
  HOTMART
}
