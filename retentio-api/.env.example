# ── App ──
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://retentio:retentio@localhost:5432/retentio_dev

# ── Redis ──
REDIS_URL=redis://localhost:6379
# Opcional: se seu Redis requer autenticação, configure abaixo
REDIS_USERNAME=
REDIS_PASSWORD=

# ── Auth ──
JWT_SECRET=change-me-256-bit-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-another-256-bit-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Encryption (AES-256 para API Keys Resend) ──
ENCRYPTION_KEY=32-bytes-hex-string-here
ENCRYPTION_IV=16-bytes-hex-string-here

# ── Logging ──
LOG_LEVEL=debug

# ── CORS ──
CORS_ORIGIN=http://localhost:3001

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Workers ──
BLOCK_CHECK_INTERVAL_MS=900000
CADENCE_CHECK_INTERVAL_MS=900000
PRR_CONCURRENCY=5

# ── Sentry (opcional) ──
SENTRY_DSN=
